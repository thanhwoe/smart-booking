// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CUSTOMER
  PROVIDER
  ADMIN
}

enum SlotStatus {
  AVAILABLE
  FULL
  CANCELLED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum EmailStatus {
  QUEUED           
  SENT             
  DELIVERED        
  DELIVERY_DELAYED 
  BOUNCED          
  COMPLAINED       
  FAILED          
}

enum SuppressionReason {
  HARD_BOUNCE 
  SOFT_BOUNCE 
  COMPLAINT   
  MANUAL      
}


model User {
  id        String   @id @default(uuid())
  clerkId   String   @unique @map("clerk_id")
  email     String   @unique
  name      String
  phone     String?
  role      UserRole @default(CUSTOMER)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  bookings  Booking[]
  slots     Slot[]    @relation("ProviderSlots")
  emailLogs EmailLog[]

  @@map("users")
}

model Service {
  id              String   @id @default(uuid())
  name            String
  description     String?
  durationMinutes Int      @map("duration_minutes")
  price           Decimal  @db.Decimal(10, 2)
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  slots Slot[]

  @@map("services")
}

model Slot {
  id          String     @id @default(uuid())
  serviceId   String     @map("service_id")
  providerId  String     @map("provider_id")
  startTime   DateTime   @map("start_time")
  endTime     DateTime   @map("end_time")
  capacity    Int        @default(1)
  bookedCount Int        @default(0) @map("booked_count")
  status      SlotStatus @default(AVAILABLE)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  service  Service   @relation(fields: [serviceId], references: [id])
  provider User      @relation("ProviderSlots", fields: [providerId], references: [id])
  bookings Booking[]

  @@index([startTime, endTime])
  @@index([serviceId, startTime])
  @@index([providerId, startTime])
  @@map("slots")
}

model Booking {
  id              String        @id @default(uuid())
  userId          String        @map("user_id")
  slotId          String        @map("slot_id")
  status          BookingStatus @default(PENDING)
  idempotencyKey  String        @unique @map("idempotency_key")
  expiresAt       DateTime      @map("expires_at")
  confirmedAt     DateTime?     @map("confirmed_at")
  cancelledAt     DateTime?     @map("cancelled_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  user    User     @relation(fields: [userId], references: [id])
  slot    Slot     @relation(fields: [slotId], references: [id])
  payment Payment?
  emailLogs EmailLog[]


  @@index([userId])
  @@index([slotId, status])
  @@index([status, expiresAt])
  @@map("bookings")
}

model Payment {
  id                   String        @id @default(uuid())
  bookingId            String        @unique @map("booking_id")
  stripeSessionId      String?       @unique @map("stripe_session_id")
  stripePaymentIntent  String?       @unique @map("stripe_payment_intent")
  amount               Decimal       @db.Decimal(10, 2)
  currency             String        @default("usd")
  status               PaymentStatus @default(PENDING)
  paidAt               DateTime?     @map("paid_at")
  refundedAt           DateTime?     @map("refunded_at")
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")

  booking Booking @relation(fields: [bookingId], references: [id])

  @@map("payments")
}

model StripeEvent {
  id            String    @id @default(uuid())
  stripeEventId String    @unique @map("stripe_event_id")
  eventType     String    @map("event_type")
  processed     Boolean   @default(false)
  processedAt   DateTime? @map("processed_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([processed])
  @@map("stripe_events")
}

model EmailLog {
  id            String      @id @default(uuid())
  resendEmailId String?     @unique @map("resend_email_id")
  bookingId     String?     @map("booking_id")
  userId        String?     @map("user_id")
  toEmail       String      @map("to_email")
  subject       String
  jobName       String      @map("job_name")
  status        EmailStatus @default(QUEUED)

  bounceType    String?     @map("bounce_type")
  bounceCode    String?     @map("bounce_code")
  bounceReason  String?     @map("bounce_reason")

  sentAt        DateTime?   @map("sent_at")
  deliveredAt   DateTime?   @map("delivered_at")
  bouncedAt     DateTime?   @map("bounced_at")
  complainedAt  DateTime?   @map("complained_at")
  openedAt      DateTime?   @map("opened_at")
  clickedAt     DateTime?   @map("clicked_at")

  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  booking Booking? @relation(fields: [bookingId], references: [id])
  user    User?    @relation(fields: [userId], references: [id])

  @@index([resendEmailId])
  @@index([bookingId])
  @@index([userId])
  @@index([status])
  @@index([toEmail])
  @@map("email_logs")
}


model EmailSuppression {
  id        String            @id @default(uuid())
  email     String            @unique 
  reason    SuppressionReason
  source    String            
  notes     String?           
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  @@index([email])
  @@map("email_suppressions")
}